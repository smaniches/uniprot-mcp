{
  "$schema": "https://modelcontextprotocol.io/schema/mcp.json",
  "name": "uniprot-mcp",
  "version": "1.0.1",
  "description": "Reference-quality Model Context Protocol server for the UniProt protein knowledgebase. Ten tools cover entry retrieval, search, sequences, features, variants, GO terms, cross-references, ID mapping, batch retrieval, and taxonomy. Every successful response carries a verifiable Provenance record (UniProt release number, release date, retrieval timestamp, resolved query URL) surfaced as a Markdown footer, JSON envelope, or PIR-style FASTA header. All tools are read-only and require no API key.",
  "homepage": "https://github.com/smaniches/uniprot-mcp",
  "license": "Apache-2.0",
  "author": {
    "name": "Santiago Maniches",
    "email": "santiago.maniches@gmail.com",
    "orcid": "https://orcid.org/0009-0005-6480-1987",
    "organization": "TOPOLOGICA LLC"
  },
  "keywords": [
    "uniprot",
    "bioinformatics",
    "proteins",
    "swiss-prot",
    "mcp",
    "model-context-protocol",
    "claude",
    "llm-tools",
    "provenance",
    "reproducibility"
  ],
  "transports": ["stdio"],
  "runtime": {
    "python": ">=3.11"
  },
  "entry": {
    "stdio": {
      "command": "uniprot-mcp"
    }
  },
  "tools": [
    "uniprot_get_entry",
    "uniprot_search",
    "uniprot_get_sequence",
    "uniprot_get_features",
    "uniprot_get_variants",
    "uniprot_get_go_terms",
    "uniprot_get_cross_refs",
    "uniprot_id_mapping",
    "uniprot_batch_entries",
    "uniprot_taxonomy_search",
    "uniprot_get_keyword",
    "uniprot_search_keywords",
    "uniprot_get_subcellular_location",
    "uniprot_search_subcellular_locations",
    "uniprot_get_uniref",
    "uniprot_search_uniref",
    "uniprot_get_uniparc",
    "uniprot_search_uniparc",
    "uniprot_get_proteome",
    "uniprot_search_proteomes",
    "uniprot_get_citation",
    "uniprot_search_citations",
    "uniprot_resolve_pdb",
    "uniprot_resolve_alphafold",
    "uniprot_resolve_interpro",
    "uniprot_resolve_chembl",
    "uniprot_get_evidence_summary",
    "uniprot_compute_properties",
    "uniprot_features_at_position",
    "uniprot_lookup_variant",
    "uniprot_get_disease_associations",
    "uniprot_get_alphafold_confidence",
    "uniprot_get_publications",
    "uniprot_resolve_orthology",
    "uniprot_target_dossier",
    "uniprot_provenance_verify"
  ],
  "toolDefaults": {
    "readOnlyHint": true,
    "openWorldHint": true,
    "destructiveHint": false
  },
  "dataSource": {
    "name": "UniProt Knowledgebase",
    "url": "https://www.uniprot.org",
    "license": "CC BY 4.0",
    "citation": "The UniProt Consortium. UniProt: the Universal Protein Knowledgebase in 2025. Nucleic Acids Research (2025). doi:10.1093/nar/gkae1010"
  },
  "support": {
    "issues": "https://github.com/smaniches/uniprot-mcp/issues",
    "documentation": "https://github.com/smaniches/uniprot-mcp/blob/main/README.md",
    "security": "https://github.com/smaniches/uniprot-mcp/blob/main/SECURITY.md"
  }
}
